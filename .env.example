# Lista completa das variáveis a cadastrar no painel do Railway (RF-03).
# Cadastrar estas variáveis no Railway; segredos nunca são versionados.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJ.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
# URL pública final em produção (mesmo domínio do Cloudflare/Railway).
# Usada no callback do Meta OAuth e no middleware — se o domínio mudar, a
# Redirect URI do app Meta (Facebook Developer) também precisa mudar (RF-04).
APP_URL=https://seu-dominio-final
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret
META_OAUTH_SCOPES=public_profile,pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish,business_management
# Google/YouTube OAuth
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret
# Agendamento roda no Supabase Cron + Edge Functions. APP_URL/CRON_SECRET nao
# sao necessarios para publicar posts; configure os secrets no Supabase.
# IA (AI Studio + Piloto + Brand DNA). Stack enxuta: DeepSeek + Pollinations.
# DeepSeek = TEXTO (copy, análise e Brand DNA) — único escritor.
DEEPSEEK_API_KEY=sua_deepseek_key
# Pollinations = IMAGEM (flux) + PESQUISA (gemini-search). Chave começa com "sk_".
# Sem esta chave, a imagem cai no render on-brand via next/og (custo zero);
# a pesquisa de contexto atual fica indisponível (erro claro, sem inventar fato).
POLLINATIONS_SECRET_KEY=sk_sua_pollinations_key
# Opcionais: modelo e custos p/ o log honesto de custo.
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_IMAGE_USD=0.002
POLLINATIONS_SEARCH_USD=0.001
# Chaves legadas/alternativas (podem ficar vazias se não estiverem em uso —
# a stack atual é DeepSeek + Pollinations).
GEMINI_API_KEY=
TAVILY_API_KEY=
DEAPI_API_KEY=
# Monitoramento de erro (RF-05/RF-06). DSN gerado no painel do Sentry.
# Sem esta variável, o Sentry fica inativo (no-op) — nada quebra.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
