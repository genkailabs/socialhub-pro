NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJ.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret
META_OAUTH_SCOPES=public_profile,pages_show_list,pages_read_engagement,instagram_basic,instagram_content_publish,business_management
APP_URL=http://localhost:3000
CRON_SECRET=defina_um_valor_aleatorio
# IA (AI Studio + Piloto).
# DeepSeek = TEXTO (legenda, hashtags e o prompt da imagem).
DEEPSEEK_API_KEY=sua_deepseek_key
# deAPI = IMAGEM (gera a arte a partir do prompt do DeepSeek). Chave começa com "dpn-sk-".
# Sem esta chave, o app cai no render on-brand via next/og (custo zero) p/ testar o texto.
DEAPI_API_KEY=dpn-sk-sua_deapi_key
# Opcionais: modelo e custo/imagem p/ o log honesto de custo.
DEAPI_IMAGE_MODEL=Flux1schnell
DEAPI_IMAGE_USD=0.003
