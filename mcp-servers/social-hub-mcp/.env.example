# ==============================================================================
# CONFIGURAÇÕES DE AMBIENTE - SOCIALHUB MCP SERVER
# ==============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais caso deseje
# executar em modo de produção. Se deixadas em branco ou preenchidas com
# "demo_token", o servidor funcionará automaticamente em modo Sandbox / Simulação.
# ==============================================================================

# --- META (INSTAGRAM & FACEBOOK GRAPH API v19.0) ---
# Token de acesso de usuário ou página da Graph API
# META_ACCESS_TOKEN=demo_token
# ID da conta comercial do Instagram (IG User ID) ou Facebook Page ID
# META_ACCOUNT_ID=mock_account_id

# --- YOUTUBE DATA API V3 ---
# Chave de API do Google Cloud com YouTube Data API v3 habilitada
# YOUTUBE_API_KEY=demo_token
# OAuth2 Access Token (necessário para upload de YouTube Shorts)
# YOUTUBE_ACCESS_TOKEN=demo_token
# ID do canal do YouTube (ex: UC_x5XG1OV2P6uZZ5FSM9Ttw)
# YOUTUBE_CHANNEL_ID=mock_channel_id

# --- TIKTOK OPEN API V2 ---
# Token de acesso OAuth do TikTok Developer
# TIKTOK_ACCESS_TOKEN=demo_token

# --- SPOTIFY WEB API ---
# Client ID e Client Secret do aplicativo Spotify Developer
# SPOTIFY_CLIENT_ID=demo_client_id
# SPOTIFY_CLIENT_SECRET=demo_client_secret
# OAuth Access Token ou Token de Podcaster
# SPOTIFY_ACCESS_TOKEN=demo_token
# ID do Show / Podcast no Spotify
# SPOTIFY_SHOW_ID=mock_show_id

# --- WHATSAPP CLOUD API (META) ---
# Token de API do WhatsApp Business (Permanent ou Temporary Token)
# WHATSAPP_API_TOKEN=demo_token
# Phone Number ID (ID do número de telefone registrado no WhatsApp Business)
# WHATSAPP_PHONE_ID=mock_phone_id
